generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id     String  @id @default(uuid()) @db.Uuid
  nombre String
  nit    String  @unique
  activo Boolean @default(true)

  users       User[]
  clientes    Cliente[]
  servicios   Servicio[]
  conductores Conductor[]

  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  vehiculos Vehiculo[]
  pedidos   Pedido[]
  facturas  Factura[]
  tasks     Task[]

  @@map("tenants")
}

model Role {
  id       String @id @default(uuid()) @db.Uuid
  nombre   String
  slug     String @unique
  permisos Json
  users    User[]

  @@map("roles")
}

model User {
  id String @id @default(uuid()) @db.Uuid

  nombre String

  email    String @unique
  password String

  roleId   String @map("role_id") @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid

  scope String @default("ERP")

  role   Role   @relation(fields: [roleId], references: [id])
  tenant Tenant @relation(fields: [tenantId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  pedidos                Pedido[]
  cotizaciones           Cotizacion[]
  tasksResponsable       Task[]          @relation("TaskResponsable")
  tasksCreador           Task[]          @relation("TaskCreador")
  iniciativasResponsable PmoInitiative[] @relation("InitiativeResponsable")
  taskComments           TaskComment[]
  areasResponsable       Area[]          @relation("AreaResponsable")
  processesResponsable   Process[]       @relation("ProcessResponsable")

  @@map("users")
}

// ==================== CONFIGURACIÓN & CATÁLOGOS ====================

model Area {
  id            String  @id @default(uuid()) @db.Uuid
  nombre        String
  codigo        String  @unique
  descripcion   String?
  responsableId String? @map("responsable_id") @db.Uuid
  estado        String  @default("ACTIVO")
  activo        Boolean @default(true)

  responsable User?      @relation("AreaResponsable", fields: [responsableId], references: [id])
  procesos    Process[]
  documentos  Document[] @relation("DocumentArea")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("areas")
}

model Process {
  id            String  @id @default(uuid()) @db.Uuid
  nombre        String
  codigo        String  @unique
  descripcion   String?
  areaId        String? @map("area_id") @db.Uuid
  responsableId String? @map("responsable_id") @db.Uuid
  estado        String  @default("ACTIVO")
  activo        Boolean @default(true)

  area        Area?      @relation(fields: [areaId], references: [id])
  responsable User?      @relation("ProcessResponsable", fields: [responsableId], references: [id])
  documentos  Document[] @relation("DocumentProcess")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([areaId])
  @@index([responsableId])
  @@map("processes")
}

model DocumentTypeRef {
  id          String  @id @default(uuid()) @db.Uuid
  nombre      String  @unique
  codigo      String  @unique
  descripcion String?
  activo      Boolean @default(true)

  documentos Document[] @relation("DocumentTipo")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("document_types")
}

model DocumentStatusRef {
  id          String  @id @default(uuid()) @db.Uuid
  nombre      String  @unique
  codigo      String  @unique
  descripcion String?
  color       String?
  activo      Boolean @default(true)

  documentos Document[] @relation("DocumentEstado")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("document_statuses")
}

model TaskStatusRef {
  id          String  @id @default(uuid()) @db.Uuid
  nombre      String  @unique
  codigo      String  @unique
  descripcion String?
  activo      Boolean @default(true)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("task_statuses")
}

// ==================== FIN CONFIGURACIÓN ====================

model Cliente {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid

  identificacion    String
  razonSocial       String  @map("razon_social")
  tipoCliente       String? @map("tipo_cliente")
  contactoPrincipal String? @map("contacto_principal")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  pedidos      Pedido[]
  cotizaciones Cotizacion[]

  @@map("clientes")
}

model Vehiculo {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid

  placa        String  @unique
  tipoVehiculo String? @map("tipo_vehiculo")
  capacidadKg  Int?    @map("capacidad_kg")
  esPropio     Boolean @default(true) @map("es_propio")

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  servicios Servicio[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  pedidos   Pedido[]

  @@map("vehiculos")
}

model Pedido {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid

  clienteId   String @map("cliente_id") @db.Uuid
  ejecutivoId String @map("ejecutivo_id") @db.Uuid

  fechaSolicitud    DateTime @default(now()) @map("fecha_solicitud")
  descripcion       String?
  tipoServicio      String?  @map("tipo_servicio")
  numeroPedido      String?  @unique @map("numero_pedido")
  origen            String?
  destino           String?
  valorTotalPactado Float?   @map("valor_total_pactado")
  origenPedido      String?  @map("origen_pedido")

  cotizacionId String? @map("cotizacion_id") @db.Uuid

  fechaProgramada DateTime? @map("fecha_programada")

  vehiculoId  String? @map("vehiculo_id") @db.Uuid
  conductorId String? @map("conductor_id") @db.Uuid

  lineaNegocio String @default("MUDANZA") @map("linea_negocio")

  estado String @default("SOLICITADO")

  tenant           Tenant              @relation(fields: [tenantId], references: [id])
  cliente          Cliente             @relation(fields: [clienteId], references: [id])
  ejecutivo        User                @relation(fields: [ejecutivoId], references: [id])
  cotizacion       Cotizacion?         @relation(fields: [cotizacionId], references: [id])
  vehiculo         Vehiculo?           @relation(fields: [vehiculoId], references: [id])
  conductor        Conductor?          @relation(fields: [conductorId], references: [id])
  servicios        Servicio[]
  facturas         Factura[]
  detallesServicio DetalleServicio[]
  evidencias       EvidenciaServicio[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("pedidos")
}

model Servicio {
  id String @id @default(uuid()) @db.Uuid

  tenantId String @map("tenant_id") @db.Uuid

  pedidoId String @map("pedido_id") @db.Uuid

  vehiculoId  String? @map("vehiculo_id") @db.Uuid
  conductorId String? @map("conductor_id") @db.Uuid

  tipoServicio String @map("tipo_servicio")

  origen  String?
  destino String?

  fechaProgramada DateTime? @map("fecha_programada")

  fechaInicio DateTime? @map("fecha_inicio")
  fechaFin    DateTime? @map("fecha_fin")

  estado String @default("PENDIENTE")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  pedido Pedido @relation(fields: [pedidoId], references: [id])

  vehiculo Vehiculo? @relation(fields: [vehiculoId], references: [id])

  conductor Conductor? @relation(fields: [conductorId], references: [id])

  gastosOperativos GastoOperativo[]

  evidencias EvidenciaServicio[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("servicios")
}

model GastoOperativo {
  id String @id @default(uuid()) @db.Uuid

  servicioId String @map("servicio_id") @db.Uuid

  tipo String

  descripcion String?

  valor Float

  fecha DateTime @default(now())

  servicio Servicio @relation(fields: [servicioId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("gastos_operativos")
}

model DetalleServicio {
  id String @id @default(uuid()) @db.Uuid

  pedidoId String @map("pedido_id") @db.Uuid

  nombre String

  cantidad Int @default(1)

  valorUnitario Float @map("valor_unitario")

  valorTotal Float @map("valor_total")

  pedido Pedido @relation(fields: [pedidoId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("detalle_servicios")
}

model Conductor {
  id String @id @default(uuid()) @db.Uuid

  tenantId String @map("tenant_id") @db.Uuid

  nombre String
  cedula String @unique

  telefono String?

  activo Boolean @default(true)

  tenant Tenant @relation(fields: [tenantId], references: [id])

  servicios Servicio[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  pedidos   Pedido[]

  @@map("conductores")
}

model Factura {
  id String @id @default(uuid()) @db.Uuid

  tenantId String @map("tenant_id") @db.Uuid
  pedidoId String @map("pedido_id") @db.Uuid

  numeroFactura String @unique @map("numero_factura")

  valor Float

  estadoPago String @default("PENDIENTE") @map("estado_pago")

  fechaEmision DateTime @default(now()) @map("fecha_emision")

  fechaVencimiento DateTime @map("fecha_vencimiento")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  pedido Pedido @relation(fields: [pedidoId], references: [id])

  pagos Pago[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("facturas")
}

model Pago {
  id String @id @default(uuid()) @db.Uuid

  facturaId String @map("factura_id") @db.Uuid

  valor Float

  metodoPago String @map("metodo_pago")

  fechaPago DateTime @default(now()) @map("fecha_pago")

  factura Factura @relation(fields: [facturaId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("pagos")
}

model Cotizacion {
  id String @id @default(uuid()) @db.Uuid

  tenantId String @db.Uuid

  clienteId    String  @db.Uuid
  cliente      Cliente @relation(fields: [clienteId], references: [id])
  ejecutivoId  String  @db.Uuid
  ejecutivo    User    @relation(fields: [ejecutivoId], references: [id])
  tipoServicio String? @map("tipo_servicio")

  descripcion      String?
  numeroCotizacion String  @unique

  origen  String
  destino String

  valorCotizado Float

  estado String @default("BORRADOR")

  fechaCreacion DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  pedidos   Pedido[]
}

model EvidenciaServicio {
  id String @id @default(uuid()) @db.Uuid

  servicioId String @map("servicio_id") @db.Uuid

  nombreArchivo String? @map("nombre_archivo")

  mimeType String? @map("mime_type")

  tamanoArchivo Int? @map("tamano_archivo")

  tipo String

  urlArchivo String? @map("url_archivo")

  observacion String?

  servicio Servicio @relation(fields: [servicioId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  pedido    Pedido?  @relation(fields: [pedidoId], references: [id])
  pedidoId  String?  @db.Uuid

  @@map("evidencias_servicio")
}

enum TaskEstado {
  PENDIENTE
  EN_CURSO
  BLOQUEADO
  FINALIZADO
  CANCELADO
}

enum TaskPrioridad {
  BAJA
  MEDIA
  ALTA
  CRITICA
}

enum TaskTipo {
  PROCEDIMIENTO
  INSTRUCTIVO
  MANUAL
  FORMATO
  MATRIZ
  ACTIVIDAD
  OTRO
}

enum DocumentType {
  MANUAL
  PROCEDIMIENTO
  FORMATO
  POLITICA
  CONTRATO
  MATRIZ
  ACTIVIDAD
  OTRO
}

enum DocumentEstado {
  VIGENTE
  EN_REVISION
  PENDIENTE_APROBACION
  OBSOLETO
  ARCHIVADO
}

model Document {
  id                         String         @id @default(uuid()) @db.Uuid
  codigo                     String?        @unique
  nombre                     String
  descripcion                String?
  tipo                       DocumentType   @default(OTRO)
  proceso                    String?
  area                       String?
  version                    String?
  responsableActualizacion   String?        @map("responsable_actualizacion")
  responsableRevision        String?        @map("responsable_revision")
  estadoDocumental           DocumentEstado @default(VIGENTE)

  areaId             String? @map("area_id_ref") @db.Uuid
  processId          String? @map("process_id") @db.Uuid
  tipoId             String? @map("tipo_id") @db.Uuid
  estadoDocumentalId String? @map("estado_documental_id") @db.Uuid

  areaRef             Area?              @relation("DocumentArea", fields: [areaId], references: [id])
  processRef          Process?           @relation("DocumentProcess", fields: [processId], references: [id])
  tipoRef             DocumentTypeRef?   @relation("DocumentTipo", fields: [tipoId], references: [id])
  estadoDocumentalRef DocumentStatusRef? @relation("DocumentEstado", fields: [estadoDocumentalId], references: [id])
  fechaCreacion       DateTime?
  fechaRevision       DateTime?
  observaciones       String?
  enlace              String?
  fuente              String?            @default("MANUAL")
  origenImportacion   Boolean            @default(false)
  activo              Boolean            @default(true)

  clienteId    String? @map("cliente_id") @db.Uuid
  programId    String? @map("program_id") @db.Uuid
  initiativeId String? @map("initiative_id") @db.Uuid
  projectId    String? @map("project_id") @db.Uuid

  cliente    PmoClient?     @relation(fields: [clienteId], references: [id])
  programa   PmoProgram?    @relation(fields: [programId], references: [id])
  iniciativa PmoInitiative? @relation(fields: [initiativeId], references: [id])
  proyecto   PmoProject?    @relation(fields: [projectId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clienteId])
  @@index([programId])
  @@index([initiativeId])
  @@index([projectId])
  @@map("documents")
}

model Task {
  id                String        @id @default(uuid()) @db.Uuid
  codigo            String        @unique
  tenantId          String        @map("tenant_id") @db.Uuid
  titulo            String
  descripcion       String?
  estado            TaskEstado    @default(PENDIENTE)
  prioridad         TaskPrioridad @default(MEDIA)
  tipo              TaskTipo      @default(ACTIVIDAD)
  codigoOrigen      String?
  area              String?
  origenImportacion Boolean       @default(false)
  fuente            String?       @default("MANUAL")
  fechaInicio       DateTime?     @map("fecha_inicio")
  fechaFin          DateTime?     @map("fecha_fin")
  fechaLimite       DateTime?     @map("fecha_limite")
  responsableId     String?       @map("responsable_id") @db.Uuid
  creadorId         String?       @map("creador_id") @db.Uuid
  projectId         String?       @map("project_id") @db.Uuid

  tenant Tenant @relation(fields: [tenantId], references: [id])

  responsable User?       @relation("TaskResponsable", fields: [responsableId], references: [id])
  creador     User?       @relation("TaskCreador", fields: [creadorId], references: [id])
  proyecto    PmoProject? @relation(fields: [projectId], references: [id])

  comentarios TaskComment[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("pmo_tasks")
}

model TaskComment {
  id         String @id @default(uuid()) @db.Uuid
  taskId     String @map("task_id") @db.Uuid
  usuarioId  String @map("usuario_id") @db.Uuid
  comentario String

  tarea   Task @relation(fields: [taskId], references: [id])
  usuario User @relation(fields: [usuarioId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")

  @@map("pmo_task_comments")
}

model PmoClient {
  id String @id @default(uuid()) @db.Uuid

  nombre String

  nit String?

  contacto String?

  email String?

  razonSocial String?

  estado String @default("ACTIVO")

  logoUrl String?

  programas  PmoProgram[]
  documentos Document[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("pmo_clients")
}

model PmoInitiative {
  id String @id @default(uuid()) @db.Uuid

  programId     String  @db.Uuid
  responsableId String? @db.Uuid

  nombre      String
  descripcion String?
  estado      String  @default("ACTIVO")
  avance      Int     @default(0)

  programa PmoProgram @relation(fields: [programId], references: [id])

  responsable User? @relation("InitiativeResponsable", fields: [responsableId], references: [id])

  proyectos  PmoProject[]
  documentos Document[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([programId])
  @@index([responsableId])
  @@map("pmo_initiatives")
}

model PmoProject {
  id String @id @default(uuid()) @db.Uuid

  initiativeId String @db.Uuid

  nombre               String
  descripcion          String?
  codigo               String?
  area                 String?
  objetivo             String?
  observaciones        String?
  estadoDocumental     String?
  fuente               String? @default("MANUAL")
  origenImportacion    Boolean @default(false)
  liderId              String?
  liderNombreImportado String?

  estado String @default("ACTIVO")
  avance Int    @default(0)

  fechaInicio DateTime?
  fechaFin    DateTime?

  iniciativa PmoInitiative @relation(fields: [initiativeId], references: [id])

  documentos Document[]
  tasks      Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([initiativeId])
  @@map("pmo_projects")
}

model PmoProgram {
  id       String @id @default(uuid()) @db.Uuid
  clientId String @db.Uuid
  nombre   String

  descripcion String?

  estado String @default("ACTIVO")

  fechaInicio DateTime?
  fechaFin    DateTime?

  avance Int @default(0)

  cliente PmoClient @relation(fields: [clientId], references: [id])

  iniciativas PmoInitiative[]
  documentos  Document[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@map("pmo_programs")
}
